# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Coverage outputs
*.out
coverage.out

# Build artefacts
/bin/
price-service

# IDE
.idea/
.vscode/
*.swp
*.swo
__debug_bin
.DS_Store

# Secrets and local env. Never commit anything matching these.
.env
.env.*
!.env.example

# Local docker-compose data
/data/

# Architecture rule 9: generated proto code is never committed.
# protocols/.gitignore also enforces this scoped to that subtree.
*.pb.go
*_grpc.pb.go
/internal/genproto/

# Local-only E2E harness (task 05.1 — never committed). Re-derive from the
# project's mimir task note on a fresh machine. .env.e2e is also matched
# above by .env.* — listed here as defence in depth.
/e2e/
.env.e2e
