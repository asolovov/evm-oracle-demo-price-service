# Copy to .env.local and fill in real values. .env.local is gitignored.
#
# NOTE: the service reads these with NO prefix (viper AutomaticEnv, no
# SetEnvPrefix). Use the exact SOURCES_* names below — a PRICE_ prefix is
# silently ignored.

# Database — used by both docker-compose and the migrate sidecar.
DATABASE_PASSWORD=price_pass

# Source API keys for the enabled keyed sources. Required at startup
# (the service fails fast if an enabled source is missing its key):
#   uniswap_v3   — crypto (The Graph gateway)
#   alpha_vantage— metals XAU/XAG only (free: alphavantage.co)
#   eia          — WTI crude   (free, instant: eia.gov/opendata/register.php)
#   fred         — WTI + S&P 500 (free: fred.stlouisfed.org/docs/api/api_key.html)
# Keyless sources (no entry needed): coingecko, binance, gold_api, yahoo,
# swissquote. Twelve Data + Stooq ship disabled.
SOURCES_UNISWAP_V3_API_KEY=
SOURCES_ALPHA_VANTAGE_API_KEY=
SOURCES_EIA_API_KEY=
SOURCES_FRED_API_KEY=
